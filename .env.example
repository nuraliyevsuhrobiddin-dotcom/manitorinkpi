# Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: table/key used to store the KPI app state as JSON
VITE_SUPABASE_STATE_TABLE=app_state
VITE_SUPABASE_STATE_ID=kpi_constants
VITE_ADMIN_EMAILS=admin@example.com

# Comma-separated origins allowed to communicate with the app iframe/window
VITE_ALLOWED_MESSAGE_ORIGINS=https://your-production-domain.uz
